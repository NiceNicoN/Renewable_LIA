#include <Stepper.h>
//#include <AccelStepper.h>
#include <DHT11.h>

const bool PRINT = false;

#define PIN_SPRINKLER_MOTOR1 9   // Connected to the Blue coloured wire
#define PIN_SPRINKLER_MOTOR2 10  // Connected to the Pink coloured wire
#define PIN_SPRINKLER_MOTOR3 11  // Connected to the Yellow coloured wire
#define PIN_SPRINKLER_MOTOR4 12  // Connected to the Orange coloured wire

#define PIN_FAN_RELAY 2
#define PIN_SPRINKLER_RELAY 3
#define PIN_HEATER_RELAY 4
#define PIN_LIGHT_RELAY 5
#define PIN_HUMIDITY_SENSOR 8
#define PIN_SPRINKLER_MODE_BUTTON 13
#define PIN_FAN_MODE_BUTTON A0

const int STEPS_PER_FULL_ROTATION = 2048;  // 28BYJ-48 has 2048 steps per rotation in full step mode as given in data sheet
const int STEPS_PER_NO_ROTATION = 0;
const int STEPS_SPEED = 15;

const int HUMIDITY_SENSOR_READ_DELAY = 3000;

int sprinklerModeCounter = 0;
int sprinklerModeState = 0;
int sprinklerModeLastState = 0;

int fanModeCounter = 0;
int fanModeState = 0;
int fanModeLastState = 0;

const Stepper myStepper = Stepper(
  STEPS_PER_FULL_ROTATION,
  PIN_SPRINKLER_MOTOR1, PIN_SPRINKLER_MOTOR2, PIN_SPRINKLER_MOTOR3, PIN_SPRINKLER_MOTOR4
);
// AccelStepper stepper(
//   4 * 2,  // For the 28BYJ-48 motor
//   PIN_SPRINKLER_MOTOR1, PIN_SPRINKLER_MOTOR3, PIN_SPRINKLER_MOTOR2, PIN_SPRINKLER_MOTOR4);
DHT11 dht11(PIN_HUMIDITY_SENSOR);

unsigned long lastTime = 0;
unsigned long lastTime_DHT = 0;

void setup() {
  Serial.begin(9600);
  for (int i = 0; i < 50; i++) Serial.println();

  pinMode(PIN_SPRINKLER_MODE_BUTTON, INPUT);
  pinMode(PIN_FAN_MODE_BUTTON, INPUT);
  pinMode(PIN_HUMIDITY_SENSOR, INPUT);

  pinMode(PIN_FAN_RELAY, OUTPUT);

  myStepper.setSpeed(STEPS_SPEED);
  //stepper.setMaxSpeed(1000.0);
  //stepper.setAcceleration(600.0);
}

int temperature = 0;
int humidity = 0;
void loop() {

  if ((millis() - lastTime_DHT) >= HUMIDITY_SENSOR_READ_DELAY) {
    int humidityStatus = dht11.readTemperatureHumidity(temperature, humidity);

    if (humidityStatus == 0) {
      if (PRINT) {
        Serial.print("Temperature: ");
        Serial.print(temperature);
        Serial.print(" °C\tHumidity: ");
        Serial.print(humidity);
        Serial.println(" %");
      }
    } else {
      Serial.println(DHT11::getErrorString(humidityStatus));
    }

    lastTime_DHT = millis();
  }

  int sprinklerMode = checkSprinklerMode();
  if (PRINT) Serial.print("Sprinkler Mode: ");
  if (PRINT) Serial.println(sprinklerMode);
  int fanMode = checkFanMode();
  if (PRINT) Serial.print("Fan Mode: ");
  if (PRINT) Serial.println(fanMode);

  performFan(fanMode);
  performHeater();
  performSprinkler(sprinklerMode);
  performLighting();

  //stepper.run();
  //delay(200);
}

int checkSprinklerMode() {
  sprinklerModeState = digitalRead(PIN_SPRINKLER_MODE_BUTTON);

  if (sprinklerModeState != sprinklerModeLastState) {
    if (sprinklerModeState == HIGH) {
      sprinklerModeCounter++;

      Serial.println("SPRINKLER MODE BUTTON (HIGH)");
      Serial.print("sprinklerModeCounter: ");
      Serial.println(sprinklerModeCounter);

    } else {
      Serial.println("SPRINKLER MODE BUTTON (LOW)");
    }

    delay(20);
    sprinklerModeLastState = sprinklerModeState;
  }

  return sprinklerModeCounter % 4;
}

int checkFanMode() {
  fanModeState = digitalRead(PIN_FAN_MODE_BUTTON);

  if (fanModeState != fanModeLastState) {
    if (fanModeState == HIGH) {
      fanModeCounter++;

      Serial.println("FAN MODE BUTTON (HIGH)");
      Serial.print("fanModeCounter: ");
      Serial.println(fanModeCounter);

    } else {
      Serial.println("FAN MODE BUTTON (LOW)");
    }

    delay(20);
    fanModeLastState = fanModeState;
  }

  return fanModeCounter % 2;
}

