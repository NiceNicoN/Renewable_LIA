  const int HUMIDITY_THRESHOLD = 40;

  if (true) {
  // if (stepper.distanceToGo() == 0) {

    if (humidity < HUMIDITY_THRESHOLD) {
      if (PRINT) Serial.println("Humidity LOW (TURN ON)");

      switch (sprinkerMode) {
        case 0:
          // Rotate fully clockwise
          myStepper.step(STEPS_PER_FULL_ROTATION);
          delay(1000);
          //stepper.move(STEPS_PER_FULL_ROTATION);
          break;
        case 1:
          myStepper.step(STEPS_PER_FULL_ROTATION);  
          delay(1000);  // Delay between rotations
          Serial.println("H");
